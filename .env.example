# =============================================================================
# StudoBot Configuration
# Копируйте этот файл в .env и заполните значения
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram Bot
# -----------------------------------------------------------------------------
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Ваш Telegram ID (для уведомлений преподавателя)
# Узнайте свой ID у @userinfobot
TEACHER_TELEGRAM_ID=123456789

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=studobot
POSTGRES_USER=studobot
POSTGRES_PASSWORD=change_this_to_secure_password

# -----------------------------------------------------------------------------
# File Storage (MinIO)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_to_secure_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=student-files

# -----------------------------------------------------------------------------
# n8n Workflow Automation
# -----------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=Europe/Moscow

# -----------------------------------------------------------------------------
# AI Integration (опционально)
# -----------------------------------------------------------------------------
# API ключ для AI-модели (OpenAI, Anthropic, или российский провайдер)
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Секретный ключ для JWT токенов (генерируйте случайную строку)
JWT_SECRET=change_this_to_random_string_at_least_32_chars

# -----------------------------------------------------------------------------
# CORS (для веб-панели)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Backup (Яндекс.Диск)
# -----------------------------------------------------------------------------
# Для бэкапа файлов на Яндекс.Диск
YANDEX_USER=
YANDEX_PASS=

# -----------------------------------------------------------------------------
# Ports (если нужно изменить стандартные)
# -----------------------------------------------------------------------------
API_PORT=8000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
