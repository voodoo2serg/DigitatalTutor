# =============================================================================
# DigitalTutor Configuration
# Копируйте этот файл в .env и заполните значения
# =============================================================================

# -----------------------------------------------------------------------------
# СЕТЬ
# -----------------------------------------------------------------------------
SERVER_IP=your.debian.ip
N8N_URL=http://localhost:5678
DOMAIN_NAME=optional.domain.com

# -----------------------------------------------------------------------------
# TELEGRAM
# -----------------------------------------------------------------------------
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Ваш Telegram ID (для уведомлений и админ-панели)
# Узнайте свой ID у @userinfobot
TEACHER_TELEGRAM_ID=123456789
TEACHER_NAME=Иванов И.И.

# -----------------------------------------------------------------------------
# БАЗА ДАННЫХ (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=teaching
POSTGRES_USER=teacher
POSTGRES_PASSWORD=change_this_to_secure_password

# -----------------------------------------------------------------------------
# ХРАНИЛИЩЕ ФАЙЛОВ (MinIO)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=teacher
MINIO_ROOT_PASSWORD=change_this_to_secure_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=student-files

# -----------------------------------------------------------------------------
# ЯНДЕКС ИНТЕГРАЦИЯ
# -----------------------------------------------------------------------------
# Яндекс.Диск - для бэкапа файлов
YANDEX_DISK_TOKEN=your_yandex_disk_oauth_token

# Яндекс.DataLens - для дашбордов аналитики
YANDEX_DATALENS_TOKEN=your_datalens_token

# Бакет для бэкапов на Яндекс.Диске
YANDEX_BACKUP_FOLDER=/studobot-backup

# Частота бэкапа (cron format)
BACKUP_CRON="0 2 * * *"

# -----------------------------------------------------------------------------
# AI / OLLAMA
# -----------------------------------------------------------------------------
# Локальная модель (Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Cerebras AI (основной провайдер)
CEREBRAS_API_KEY=your_cerebras_key

# OpenRouter (резервный провайдер)
OPENROUTER_API_KEY=your_openrouter_key

# HuggingFace (опционально)
HUGGINGFACE_API_KEY=your_huggingface_key

# OpenAI API (опционально, для fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Бюджет на AI (USD в год)
AI_BUDGET_YEARLY=20

# Пороговые значения для AI-анализа
AI_DETECTION_THRESHOLD=0.6
PLAGIARISM_THRESHOLD=0.4

# -----------------------------------------------------------------------------
# АНТИПЛАГИАТ
# -----------------------------------------------------------------------------
# Название системы антиплагиата
ANTIPLAG_SYSTEM_NAME=Антиплагиат ВУЗ

# URL системы антиплагиата (если есть API)
ANTIPLAG_URL=https://antiplagiat.university.ru

# Коды для проверок (через запятую)
ANTIPLAG_CODES=CODE1,CODE2,CODE3

# -----------------------------------------------------------------------------
# NOCODB
# -----------------------------------------------------------------------------
NOCODB_JWT_SECRET=change_this_to_random_string

# -----------------------------------------------------------------------------
# n8n WORKFLOWS
# -----------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=change_this_to_random_string
WEBHOOK_URL=http://localhost:5678/

# -----------------------------------------------------------------------------
# БЕЗОПАСНОСТЬ
# -----------------------------------------------------------------------------
# Секретный ключ для JWT токенов (генерируйте случайную строку)
JWT_SECRET=change_this_to_random_string_at_least_32_chars

# Секрет для webhook'ов
WEBHOOK_SECRET=change_this_to_random_16_chars

# Backend API Key (для бота)
BACKEND_API_KEY=change_this_to_random_api_key

# Разрешённые IP для админ-панели (через запятую)
ALLOWED_IPS=127.0.0.1,192.168.1.0/24

# -----------------------------------------------------------------------------
# CORS (для веб-панели)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# БЭКАПЫ
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# ЛОГИРОВАНИЕ
# -----------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# -----------------------------------------------------------------------------
# ПОРТЫ (если нужно изменить стандартные)
# -----------------------------------------------------------------------------
API_PORT=8000
FRONTEND_PORT=3000

# -----------------------------------------------------------------------------
# МЕТРИКИ И МОНИТОРИНГ
# -----------------------------------------------------------------------------
# Prometheus (опционально)
METRICS_ENABLED=false
METRICS_PORT=9090
